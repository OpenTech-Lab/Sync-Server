# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://sync:syncdev@localhost:5432/sync
# Used by Docker Compose to set the postgres container password
POSTGRES_PASSWORD=syncdev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Token expiry in seconds (default: 1h access, 30d refresh)
JWT_ACCESS_EXPIRY_SECS=3600
JWT_REFRESH_EXPIRY_SECS=2592000

# ─── Server ───────────────────────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development
# In production this must be true; startup will fail otherwise
ENFORCE_HTTPS=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ─── Instance ─────────────────────────────────────────────────────────────────
# Human-readable name shown in federation discovery
INSTANCE_NAME=my-planet
# Admin contact shown in instance metadata
ADMIN_EMAIL=admin@example.com
# Public domain used for ActivityPub actor URIs, WebFinger, and nginx TLS
INSTANCE_DOMAIN=sync.example.com
# Optional: hard cap on registered users (omit to use suggested limit from host specs)
# MAX_USERS=200

# ─── Federation (ActivityPub) ─────────────────────────────────────────────────
# Comma-separated denylist of remote hosts (e.g., "bad.example,spam.example")
FEDERATION_DENYLIST=
# Max clock drift allowed for signed inbound requests (seconds)
FEDERATION_SIGNATURE_WINDOW_SECS=300
# Max outbound delivery attempts before moving to dead-letter
FEDERATION_MAX_DELIVERY_ATTEMPTS=5
# Public key fetch cache TTL (seconds)
FEDERATION_KEY_CACHE_TTL_SECS=300
# Inbound inbox HTTP rate limiting by source IP
FEDERATION_INBOX_RPS=20
FEDERATION_INBOX_BURST=40

# ─── Encrypted Backup (opt-in) ────────────────────────────────────────────────
# Server-side AES-256 backup encryption key (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# BACKUP_ENCRYPTION_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Obtain a free API key at https://resend.com
# If unset, password-reset emails are silently skipped (useful for local dev)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@example.com

# ─── Push Notifications (APNs) ────────────────────────────────────────────────
# Push routing mode:
# - relay  (default): forward iOS push payloads to notification_webhook_url
# - direct: send iOS push directly via APNs (requires APNS_* keys below)
# - hybrid: try direct APNs first, fall back to relay on failure
#
# In relay mode the server forwards push payloads to the publisher-hosted relay
# at https://push.sync.icyanstudio.net which delivers them via APNs to the
# official mobile app. Operators can override the relay URL from the admin
# dashboard Config page (must be a valid https URL).
PUSH_DELIVERY_MODE=relay
# Optional shared secret header for relay webhook (`x-sync-push-secret`).
# Set on both sending servers and relay server.
# PUSH_RELAY_SHARED_SECRET=change-me
#
# Optional direct APNs delivery for iOS background/terminated notifications.
# Used in direct/hybrid modes only.
# Apple Team ID and Key ID from Certificates, Identifiers & Profiles.
# APNS_TEAM_ID=AB12CD34EF
# APNS_KEY_ID=1A2B3C4D5E
# iOS bundle id (must match app's aps topic).
# APNS_BUNDLE_ID=com.example.sync
# Raw .p8 content (single-line with \n escapes) or base64-encoded PEM content.
# APNS_PRIVATE_KEY_P8=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Use Apple's sandbox APNs host for development builds.
APNS_USE_SANDBOX=false

# ─── Anti-Spam (ALTCHA) ───────────────────────────────────────────────────────
# HMAC key for generating ALTCHA proof-of-work challenges.
# If unset, ALTCHA verification is disabled.
# Generate a random hex string: openssl rand -hex 32
# ALTCHA_HMAC_KEY=change-me-in-production

# ─── Observability ────────────────────────────────────────────────────────────
# Tracing level: error | warn | info | debug | trace
RUST_LOG=sync_server=info,actix_web=info
