# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://sync:syncdev@localhost:5432/sync
# Used by Docker Compose to set the postgres container password
POSTGRES_PASSWORD=syncdev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Token expiry in seconds (default: 1h access, 30d refresh)
JWT_ACCESS_EXPIRY_SECS=3600
JWT_REFRESH_EXPIRY_SECS=2592000

# ─── Server ───────────────────────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development
# In production this must be true; startup will fail otherwise
ENFORCE_HTTPS=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ─── Instance ─────────────────────────────────────────────────────────────────
# Human-readable name shown in federation discovery
INSTANCE_NAME=my-planet
# Admin contact shown in instance metadata
ADMIN_EMAIL=admin@example.com
# Public domain used for ActivityPub actor URIs, WebFinger, and nginx TLS
INSTANCE_DOMAIN=sync.example.com
# Optional: hard cap on registered users (omit to use suggested limit from host specs)
# MAX_USERS=200

# ─── Federation (ActivityPub) ─────────────────────────────────────────────────
# Comma-separated denylist of remote hosts (e.g., "bad.example,spam.example")
FEDERATION_DENYLIST=
# Max clock drift allowed for signed inbound requests (seconds)
FEDERATION_SIGNATURE_WINDOW_SECS=300
# Max outbound delivery attempts before moving to dead-letter
FEDERATION_MAX_DELIVERY_ATTEMPTS=5
# Public key fetch cache TTL (seconds)
FEDERATION_KEY_CACHE_TTL_SECS=300
# Inbound inbox HTTP rate limiting by source IP
FEDERATION_INBOX_RPS=20
FEDERATION_INBOX_BURST=40

# ─── Encrypted Backup (opt-in) ────────────────────────────────────────────────
# Server-side AES-256 backup encryption key (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
# BACKUP_ENCRYPTION_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Obtain a free API key at https://resend.com
# If unset, password-reset emails are silently skipped (useful for local dev)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@example.com

# ─── Observability ────────────────────────────────────────────────────────────
# Tracing level: error | warn | info | debug | trace
RUST_LOG=sync_server=info,actix_web=info
